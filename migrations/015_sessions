CREATE INDEX idx_sessions_token ON sessions(token);

CREATE TABLE sessions (
    id UUID NOT NULL DEFAULT gen_random_uuid(),
    user_id UUID NOT NULL,
    token TEXT NOT NULL,
    expires_at TIMESTAMPTZ NOT NULL,
    created_at TIMESTAMPTZ NOT NULL DEFAULT now(),

    -- Constraints
    CONSTRAINT sessions_pkey PRIMARY KEY (id),

    -- Each token should be unique (recommended)
    CONSTRAINT sessions_token_unique UNIQUE (token),

    -- Foreign key to users table
    CONSTRAINT sessions_user_id_fkey FOREIGN KEY (user_id)
        REFERENCES users(id)
        ON DELETE CASCADE
);
-- Migration: drop end_session RPC and recreate ended_at column fresh
-- This will remove the RPC function and recreate the ended_at column to ensure a clean column state.

-- Drop the RPC if it exists
DROP FUNCTION IF EXISTS end_session(UUID, TEXT);

-- Drop existing column and recreate it (fresh)
ALTER TABLE IF EXISTS sessions
  DROP COLUMN IF EXISTS ended_at;

ALTER TABLE IF EXISTS sessions
  ADD COLUMN IF NOT EXISTS ended_at TIMESTAMPTZ;

-- Recreate indexes
CREATE INDEX IF NOT EXISTS idx_sessions_ended_at ON sessions (ended_at);
CREATE INDEX IF NOT EXISTS idx_sessions_created_at ON sessions (created_at);
CREATE INDEX IF NOT EXISTS idx_sessions_user_id ON sessions (user_id);

