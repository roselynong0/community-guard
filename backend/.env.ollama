# ============================================================================
# OLLAMA CONFIGURATION
# ============================================================================
# Ollama base URL (default: http://localhost:11434)
OLLAMA_BASE_URL=http://localhost:11434

# LLM Model (use deepseek-r1:1.5b-q4 for faster responses)
# Options: deepseek-r1:1.5b-q4 (fast), phi4:mini-q4_0 (slow), mistral, llama2
LLM_MODEL=deepseek-r1:1.5b-q4

# Embedding Model (bge-m3 recommended for semantic search)
# Options: bge-m3, nomic-embed-text, all-minilm
EMBED_MODEL=bge-m3

# Vector database persistence directory (optional)
# If not set, uses default: backend/chroma_db
# CHROMA_DB_PATH=/path/to/chroma_db

# ============================================================================
# IMPORTANT SETUP INSTRUCTIONS
# ============================================================================
# Before running the application, ensure Ollama is running:
#
# 1. Install Ollama from https://ollama.ai
#
# 2. In a separate terminal, start Ollama server:
#    ollama serve
#
# 3. Pull the required models (in another terminal):
#    ollama pull phi4:mini-q4_0   # Main LLM (~5GB)
#    ollama pull bge-m3           # Embedding model (~0.6GB)
#
# 4. Verify models are available:
#    curl http://localhost:11434/api/tags
#
# 5. Run this Flask app:
#    python run.py
#
# The chatbot will automatically initialize RAG collections on first /chat request
# ============================================================================
